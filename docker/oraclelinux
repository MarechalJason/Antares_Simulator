FROM oraclelinux:8

# update repo
RUN dnf update -y && \
    dnf install redhat-lsb-core

# install python & modules
RUN dnf install -y python3 python3-pip && \
    pip3 install --user pandas numpy pytest

# Install build tools
RUN dnf install -y epel-release git cmake wget rpm-build && \
    dnf install -y unzip libuuid-devel gcc-toolset-9-toolchain \
    		   perl-IPC-Cmd perl-Text-Template perl-Data-Dumper perl-Time-Piece \
		   bison flex