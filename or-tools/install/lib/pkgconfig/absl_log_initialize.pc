Version: 20250512
Requires: absl_config = 20250512, absl_log_globals = 20250512, absl_log_internal_globals = 20250512, absl_time = 20250512
Libs: -L${libdir}  -labsl_log_initialize 
Cflags: -I${includedir} -DNOMINMAX
