URL: https://abseil.io/
Version: 20250512
Requires: absl_core_headers = 20250512, absl_log_internal_message = 20250512, absl_log_internal_nullstream = 20250512, absl_log_severity = 20250512
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
