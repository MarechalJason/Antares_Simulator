URL: https://abseil.io/
Version: 20250512
Requires: absl_core_headers = 20250512, absl_exponential_biased = 20250512
Libs: -L${libdir}  -labsl_periodic_sampler 
Cflags: -I${includedir} -DNOMINMAX
